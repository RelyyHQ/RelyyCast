{
  "schemaVersion": 1,
  "assets": [
    {
      "id": "mediamtx-config",
      "required": true,
      "platform": "any",
      "source": "binaries/mediamtx/mediamtx.yml",
      "destination": "build/mediamtx/mediamtx.yml",
      "executable": false
    },
    {
      "id": "mediamtx-host-binary",
      "required": true,
      "platform": "host",
      "sourceByPlatform": {
        "win": "binaries/mediamtx/win/mediamtx.exe",
        "darwin": "binaries/mediamtx/mac/mediamtx",
        "linux": "binaries/mediamtx/linux/mediamtx"
      },
      "destinationByPlatform": {
        "win": "build/mediamtx/win/mediamtx.exe",
        "darwin": "build/mediamtx/mac/mediamtx",
        "linux": "build/mediamtx/linux/mediamtx"
      },
      "executable": true
    },
    {
      "id": "cloudflared-host-binary",
      "required": true,
      "platform": "host",
      "sourceByPlatform": {
        "win": "binaries/cloudflared/win/cloudflared.exe",
        "darwin": "binaries/cloudflared/mac/cloudflared",
        "linux": "binaries/cloudflared/linux/cloudflared"
      },
      "destinationByPlatform": {
        "win": "build/bin/cloudflared.exe",
        "darwin": "build/bin/cloudflared",
        "linux": "build/bin/cloudflared"
      },
      "executable": true
    }
  ]
}
